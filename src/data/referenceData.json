  "freight_logic": {
    "origin": "Bradford, ON",
    "truck_type": "FTL unshared flatbed (always)",
    "base_rate_per_km": 4.0,
    "minimum": 4000,
    "overweight_threshold_lbs": 40000,
    "overweight_surcharge": 1500,
    "remote_modifiers": {
      "none": 0,
      "moderate": 500,
      "remote": 1500,
      "extreme": 3000
    },
    "formula": "MAX($4,000, distance_km x $4.00) + remote_modifier + overweight_surcharge",
